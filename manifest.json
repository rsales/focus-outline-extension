{
  "manifest_version": 3,
  "name": "Focus Outline Helper",
  "version": "1.0.0",
  "description": "Highlight focused elements for better accessibility",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/off.png",
      "32": "icons/off.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}